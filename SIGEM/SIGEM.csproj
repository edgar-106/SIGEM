<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <Compile Update="Vista\SigemVista.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Update="Vista\SigemVista.Designer.cs">
      <DependentUpon>SigemVista.cs</DependentUpon>
    </Compile>
    <EmbeddedResource Update="Vista\SigemVista.resx">
      <DependentUpon>SigemVista.cs</DependentUpon>
    </EmbeddedResource>
  </ItemGroup>

</Project>
